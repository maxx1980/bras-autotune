#!/home/maxx/bras-autotune/.venv/bin/python3
# EASY-INSTALL-ENTRY-SCRIPT: 'bras-autotune','console_scripts','bras-autotune'
__requires__ = 'bras-autotune'
import re
import sys
from pkg_resources import load_entry_point

if __name__ == '__main__':
    sys.argv[0] = re.sub(r'(-script\.pyw?|\.exe)?$', '', sys.argv[0])
    sys.exit(
        load_entry_point('bras-autotune', 'console_scripts', 'bras-autotune')()
    )
